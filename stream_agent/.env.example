# Copy to `.env` (in this folder) for local dev / before `adk deploy`. ADK auto-loads it
# and ships every var as a deployed env_var. One KEY=value per line.

# --- Gemini backend (Vertex AI) ---
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=gm-test-337806
GOOGLE_CLOUD_LOCATION=asia-southeast1
# (run `gcloud auth application-default login` for local Vertex access)

STREAM_MODEL=gemini-3.1-flash-lite
# gemini-3.x flash-lite is served ONLY on the GLOBAL Vertex endpoint; "global" routes the model
# there (via the _GlobalGemini api_client override) while GOOGLE_CLOUD_LOCATION stays regional.
# Leave empty to use a regional model like gemini-2.5-flash.
STREAM_MODEL_LOCATION=global
STREAM_SUBSCRIBER_ID=SUB-IN-100023
STREAM_PLAN_TIER=Premium-HD

# --- MCP servers (public Cloud Run, asia-southeast1) ---
# Both are public/unauthenticated; the Agent Gateway governs egress. So NO tokens,
# NO OIDC audience, NO proxy — leave those unset.
PUBLIC_MCP_URL=https://zee5-catalog-mcp-tz5avjn3mq-as.a.run.app/mcp
PRIVATE_MCP_URL=https://zee5-subscriber-mcp-tz5avjn3mq-as.a.run.app/mcp

# Gateway-bound deployment: Agent Identity tokens are certificate-bound; ADK's MCP transport
# can't present the binding, so opt out (mints normal unbound tokens for the agent's own
# *.googleapis.com legs). Do NOT set GOOGLE_API_USE_CLIENT_CERTIFICATE=false (the agent->gateway
# leg IS the mTLS channel — disabling it breaks egress).
GOOGLE_API_PREVENT_AGENT_TOKEN_SHARING_FOR_GCP_SERVICES=false

# --- Runtime behaviour ---
# Return MCP tool errors to the model instead of failing the turn (resilient to a
# transient gateway/MCP hiccup).
ADK_ENABLE_MCP_GRACEFUL_ERROR_HANDLING=1
# Agent Engine OpenTelemetry tracing (egress to telemetry/cloudtrace is covered by the
# bootstrap registry registration in DEPLOY.md Step 2b).
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true

# Leave UNSET (legacy paths, inert under the gateway):
# PUBLIC_MCP_TOKEN=     PRIVATE_MCP_TOKEN=     PUBLIC_MCP_AUDIENCE=     PROXY_SERVER_URL=
